# Copy this file to .env and adjust values for your environment.
# Required for running the project locally.

# Which settings module to use (local run)
DJANGO_SETTINGS_MODULE=config.settings.development

# Django secret key (generate a new one for production)
SECRET_KEY=your-secret-key

# Production: comma-separated list of allowed hosts
# ALLOWED_HOSTS=example.com,www.example.com

# Optional (Docker): allow all hosts or set explicit domains
# ALLOWED_HOSTS=localhost,127.0.0.1

# Optional (Docker): enable PostgreSQL only if needed
# USE_POSTGRES=1
# POSTGRES_DB=intus
# POSTGRES_USER=intus
# POSTGRES_PASSWORD=intus
# POSTGRES_HOST=db
# POSTGRES_PORT=5432

# Frontend (Vite): backend URL for API calls
# VITE_API_BASE_URL=http://127.0.0.1:8000
